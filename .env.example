# Hyglow — copy variables into the service-specific env files (never commit real secrets).

# --- backend/.env ---
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require
# JWT_SECRET=change-me-use-openssl-rand-hex-32
# APP_NAME=Hyglow
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# --- frontend/.env.local ---
# BACKEND_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
