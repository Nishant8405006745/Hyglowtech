# Copy to .env and fill values. Never commit .env.

# Neon PostgreSQL (use pooled connection string for serverless)
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT signing — use a long random string in production (openssl rand -hex 32)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Hyglow

# CORS — comma-separated origins (Next.js dev + Vercel preview/prod)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Password reset — link host (must match your Next.js URL). Reset links are logged at INFO if email is not set up.
FRONTEND_BASE_URL=http://localhost:3000
# LOG_PASSWORD_RESET_LINKS=false
