# Browser-visible API base (optional; BFF proxy is recommended — see BACKEND_URL)
NEXT_PUBLIC_APP_NAME=Hyglow

# Canonical URL for next-seo JSON-LD and absolute links (your Vercel domain in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side only: FastAPI origin (no trailing slash). Used by Route Handlers to proxy /api/v1/*
BACKEND_URL=http://127.0.0.1:8000
# Render (see root render.yaml): BACKEND_URL=https://hyglowtech-api.onrender.com
